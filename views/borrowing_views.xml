<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ======================================
                BORROWING FORM
    ======================================= -->
    <record id="library_borrowing_form" model="ir.ui.view">
        <field name="name">library.borrowing.form</field>
        <field name="model">library.borrowing</field>
        <field name="arch" type="xml">
            <form string="Peminjaman Buku">

                <header>

                    <button name="action_borrow"
                            string="Pinjam"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>

                    <button name="action_return"
                            string="Kembalikan"
                            type="object"
                            class="btn-success"
                            invisible="state not in ('borrowed','overdue')"/>

                    <button name="action_check_overdue"
                            string="Cek Terlambat"
                            type="object"
                            class="btn-warning"
                            invisible="state != 'borrowed'"/>

                    <button name="action_cancel"
                            string="Batalkan"
                            type="object"
                            invisible="state in ('returned','cancel')"/>

                    <field name="state" widget="statusbar"/>

                </header>

                <sheet>

                    <group>

                        <group>
                            <field name="name" readonly="1"/>
                            <field name="book_id"/>
                            <field name="borrower_id"/>
                            <field name="notes"/>
                        </group>

                        <group>
                            <field name="borrow_date"/>
                            <field name="due_date"/>
                            <field name="return_date" readonly="1"/>
                        </group>

                    </group>

                </sheet>

            </form>
        </field>
    </record>


    <!-- ======================================
                BORROWING LIST
    ======================================= -->
    <record id="library_borrowing_list" model="ir.ui.view">
        <field name="name">library.borrowing.list</field>
        <field name="model">library.borrowing</field>
        <field name="arch" type="xml">
            <list>

                <field name="name"/>
                <field name="book_id"/>
                <field name="borrower_id"/>
                <field name="borrow_date"/>
                <field name="due_date"/>
                <field name="return_date"/>
                <field name="state"/>

            </list>
        </field>
    </record>


    <!-- ======================================
                BORROWING SEARCH
    ======================================= -->
    <record id="library_borrowing_search" model="ir.ui.view">
        <field name="name">library.borrowing.search</field>
        <field name="model">library.borrowing</field>
        <field name="arch" type="xml">
            <search>

                <field name="name"/>
                <field name="book_id"/>
                <field name="borrower_id"/>

                <filter string="Draft"
                        name="draft"
                        domain="[('state','=','draft')]"/>

                <filter string="Dipinjam"
                        name="borrowed"
                        domain="[('state','=','borrowed')]"/>

                <filter string="Terlambat"
                        name="overdue"
                        domain="[('state','=','overdue')]"/>

                <filter string="Dikembalikan"
                        name="returned"
                        domain="[('state','=','returned')]"/>

                <filter string="Dibatalkan"
                        name="cancel"
                        domain="[('state','=','cancel')]"/>

            </search>
        </field>
    </record>


    <!-- ======================================
                ACTION
    ======================================= -->
    <record id="library_borrowing_action" model="ir.actions.act_window">
        <field name="name">Peminjaman Buku</field>
        <field name="res_model">library.borrowing</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="library_borrowing_search"/>
    </record>


    <!-- ======================================
                MENU
    ======================================= -->

    <menuitem
        id="library_root"
        name="Perpustakaan"
        sequence="10"/>

    <menuitem
        id="library_book_menu"
        name="Buku"
        parent="library_root"
        action="library_book_action"
        sequence="10"/>

    <menuitem
        id="library_category_menu"
        name="Kategori"
        parent="library_root"
        action="library_category_action"
        sequence="20"/>

    <menuitem
        id="library_borrowing_menu"
        name="Peminjaman"
        parent="library_root"
        action="library_borrowing_action"
        sequence="30"/>

</odoo>